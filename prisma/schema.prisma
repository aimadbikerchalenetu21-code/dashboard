generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Store {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([slug])
}

model Client {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders      Order[]
  credentials Credential[]

  @@index([email])
}

enum PlanDuration {
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
  ONE_YEAR
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

model Order {
  id           String       @id @default(cuid())
  storeId      String
  clientId     String
  planName     String
  planDuration PlanDuration
  amountCents  Int
  currency     String       @default("usd")
  notes        String?      // optional admin notes
  status       OrderStatus  @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  store       Store        @relation(fields: [storeId], references: [id])
  client      Client       @relation(fields: [clientId], references: [id])
  credentials Credential[]

  @@index([storeId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model Credential {
  id              String    @id @default(cuid())
  clientId        String
  orderId         String
  m3uUrl          String
  xtreamHost      String
  xtreamUsername  String
  xtreamPassword  String    // AES-256 encrypted
  expiresAt       DateTime
  deliveredAt     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client       Client        @relation(fields: [clientId], references: [id])
  order        Order         @relation(fields: [orderId], references: [id])
  deliveryLogs DeliveryLog[]

  @@index([clientId])
  @@index([orderId])
  @@index([isActive])
  @@index([expiresAt])
}

enum DeliveryChannel {
  EMAIL
  WHATSAPP
}

enum DeliveryStatus {
  SENT
  FAILED
  PENDING
}

model DeliveryLog {
  id           String          @id @default(cuid())
  credentialId String
  channel      DeliveryChannel
  status       DeliveryStatus  @default(PENDING)
  sentAt       DateTime?
  error        String?
  createdAt    DateTime        @default(now())

  credential Credential @relation(fields: [credentialId], references: [id])

  @@index([credentialId])
  @@index([status])
  @@index([channel])
}

// NextAuth required models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
